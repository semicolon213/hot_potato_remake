# Hot Potato ERP 환경변수 (V2 JSON 형식)
# 이 파일을 .env로 복사한 뒤 값을 수정하세요.

VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_APP_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec

# ACCOUNT_EVIDENCE: 각 장부 폴더 안의 증빙 하위폴더 이름 (예: evidence, 증빙).
# 웹앱이 createLedger 시 evidenceFolderName으로 전달함. Apps Script «프로젝트 설정 → 스크립트 속성»
# 의 EVIDENCE_FOLDER_NAME이 예전에 증빙으로만 남아 있으면, 요청에 필드가 없을 때 그 값이 쓰일 수 있음.
# (속성을 비우거나 .env와 같은 문자열로 맞추세요. 새 InitialSetup은 기본 evidence만 넣음.)
# ※ GAS Main.gs parseRequest는 JSON 본문이 쿼리스트링보다 우선하도록 수정됨(빈 쿼리로 evidenceFolderName이 지워지던 문제 방지) — 반드시 최신 스크립트 배포.
VITE_FOLER_NAME={
  "ROOT": "hot_potato_remake",
  "DOCUMENT": "document",
  "S_DOC": "shared_documents",
  "P_DOC": "personal_documents",
  "S_TEMP": "shared_forms",
  "P_TEMP": "personal_forms",
  "WORKFLOW": "workflow",
  "ACCOUNT": "account",
  "ACCOUNT_EVIDENCE": "evidence",
  "NOTICE_PARENT": "notice",
  "NOTICE_ATTACH": "attached_file"
}

VITE_SPREADSHEET_NAME={
  "CONFIG": "user_setting",
  "NOTICE": "notice",
  "CALENDAR_PROFESSOR": "calendar_professor",
  "CALENDAR_STUDENT": "calendar_student",
  "CALENDAR_COUNCIL": "calendar_council",
  "CALENDAR_ADJ_PROFESSOR": "calendar_adj_professor",
  "CALENDAR_ASSISTANT": "calendar_assistant",
  "STUDENT": "student",
  "STAFF": "staff",
  "TAG": "static_tag"
}

VITE_SHEET_NAME={
  "DEFAULT": "시트1",
  "WORKFLOW_TEMPLATE": "workflow_templates",
  "WORKFLOW_HISTORY": "workflow_history",
  "WORKFLOW_DOCUMENT": "workflow_documents",
  "INFO": "info",
  "ISSUE": "std_issue",
  "COMMITTEE": "committee",
  "CONFIG_FAVORITE": "favorite",
  "CONFIG_TAG": "tag",
  "CONFIG_DASHBOARD": "dashboard",
  "CONFIG_SCHEDULE": "schedule",
  "EMPLOYMENT": "employment",
  "FIELD": "field"
}

VITE_GROUP_EMAIL={
  "STUDENT": "student_hp@googlegroups.com",
  "PROFESSOR": "professor_hp@googlegroups.com",
  "COUNCIL": "std_council_hp@googlegroups.com",
